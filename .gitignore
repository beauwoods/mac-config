# Generated by scripts/preflight.sh — contain old-machine-specific data,
# not portable. The placeholder versions of these files are committed;
# the populated versions should not be.
configs/installed_apps.txt
configs/defaults_capture.txt

# Ansible dry-run output
ansible_check.log
preflight_run.log

# SSH private keys — these must live in 1Password, not in the repo.
# Public keys (*.pub) and config are fine to commit.
configs/ssh/id_rsa
configs/ssh/id_ed25519
configs/ssh/id_ecdsa
configs/ssh/id_dsa
configs/ssh/id_*
!configs/ssh/id_*.pub
!configs/ssh/config
!configs/ssh/README.md
